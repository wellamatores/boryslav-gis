<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Розвиток проекту — Roadmap | Цифровий двійник Борислава</title>

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <style>
        /* ===== RESET & BASE ===== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #0a0e17;
            color: #e0e0e0;
            min-height: 100vh;
            padding: 20px;
            line-height: 1.6;
        }

        /* ===== CONTAINER ===== */
        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        /* ===== HEADER ===== */
        .header {
            text-align: center;
            padding: 40px 20px 30px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.06);
            margin-bottom: 40px;
        }

        .header .logo {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 14px;
            margin-bottom: 10px;
        }

        .header .logo .coatsmall {
            width: 48px;
            height: 58px;
            opacity: 0.95;
            flex-shrink: 0;
        }

        .header .logo .coatsmall svg {
            width: 100%;
            height: 100%;
        }

        .header h1 {
            font-size: 36px;
            font-weight: 800;
            background: linear-gradient(135deg, #fdcb6e, #f39c12);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            letter-spacing: 1px;
        }

        .header .subtitle {
            font-size: 18px;
            color: #8892a0;
            letter-spacing: 0.5px;
        }

        .header .badge {
            display: inline-block;
            margin-top: 12px;
            padding: 6px 20px;
            border-radius: 9999px;
            font-size: 13px;
            font-weight: 600;
            background: rgba(253, 203, 110, 0.15);
            color: #fdcb6e;
            border: 1px solid rgba(253, 203, 110, 0.2);
        }

        /* ===== BACK BUTTON ===== */
        .back-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: #8892a0;
            text-decoration: none;
            font-size: 14px;
            padding: 8px 16px;
            border-radius: 8px;
            border: 1px solid rgba(255, 255, 255, 0.06);
            transition: all 0.3s ease;
            margin-bottom: 20px;
        }

        .back-btn:hover {
            background: rgba(253, 203, 110, 0.08);
            border-color: rgba(253, 203, 110, 0.2);
            color: #fdcb6e;
        }

        /* ===== SECTION ===== */
        .section {
            margin-bottom: 50px;
        }

        .section-title {
            font-size: 28px;
            font-weight: 700;
            color: #fdcb6e;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 12px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.04);
            padding-bottom: 12px;
        }

        .section-title i {
            font-size: 26px;
        }

        /* ===== STATS ===== */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
            gap: 16px;
            margin-top: 20px;
        }

        .stat-card {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.04);
            border-radius: 12px;
            padding: 16px 20px;
            text-align: center;
            transition: all 0.3s ease;
        }

        .stat-card:hover {
            background: rgba(255, 255, 255, 0.04);
            border-color: rgba(253, 203, 110, 0.1);
            transform: translateY(-2px);
        }

        .stat-card .number {
            font-size: 32px;
            font-weight: 800;
            color: #fdcb6e;
        }

        .stat-card .label {
            font-size: 13px;
            color: #8892a0;
            margin-top: 4px;
        }

        /* ===== ROADMAP ===== */
        .roadmap {
            display: flex;
            flex-direction: column;
            gap: 0;
            position: relative;
            padding-left: 40px;
        }

        .roadmap::before {
            content: '';
            position: absolute;
            left: 14px;
            top: 10px;
            bottom: 10px;
            width: 3px;
            background: linear-gradient(to bottom, #fdcb6e, #1a3d7a, #b31b1b);
            border-radius: 2px;
        }

        .roadmap-item {
            position: relative;
            padding: 20px 24px;
            margin-bottom: 10px;
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.04);
            border-radius: 12px;
            transition: all 0.3s ease;
        }

        .roadmap-item:hover {
            background: rgba(255, 255, 255, 0.04);
            border-color: rgba(253, 203, 110, 0.1);
            transform: translateX(4px);
        }

        .roadmap-item::before {
            content: '';
            position: absolute;
            left: -34px;
            top: 28px;
            width: 14px;
            height: 14px;
            border-radius: 50%;
            border: 3px solid #fdcb6e;
            background: #0a0e17;
            z-index: 1;
        }

        .roadmap-item.completed::before {
            background: #81c784;
            border-color: #81c784;
            box-shadow: 0 0 20px rgba(129, 199, 132, 0.3);
        }

        .roadmap-item.in-progress::before {
            background: #fdcb6e;
            border-color: #fdcb6e;
            animation: pulse-dot 2s infinite;
        }

        @keyframes pulse-dot {
            0%,
            100% {
                box-shadow: 0 0 0 0 rgba(253, 203, 110, 0.4);
            }
            50% {
                box-shadow: 0 0 0 8px rgba(253, 203, 110, 0);
            }
        }

        .roadmap-item .phase {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #fdcb6e;
            margin-bottom: 4px;
        }

        .roadmap-item .phase i {
            margin-right: 6px;
        }

        .roadmap-item .title {
            font-size: 20px;
            font-weight: 700;
            color: #e0e0e0;
            margin-bottom: 6px;
        }

        .roadmap-item .desc {
            font-size: 14px;
            color: #8892a0;
            line-height: 1.7;
            margin-bottom: 10px;
        }

        .roadmap-item .tags {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
        }

        .roadmap-item .tags span {
            font-size: 11px;
            padding: 2px 12px;
            border-radius: 20px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.06);
            color: #b0b8c4;
        }

        .roadmap-item .tags .tag-done {
            color: #81c784;
            border-color: rgba(129, 199, 132, 0.2);
            background: rgba(129, 199, 132, 0.05);
        }

        .roadmap-item .tags .tag-progress {
            color: #fdcb6e;
            border-color: rgba(253, 203, 110, 0.2);
            background: rgba(253, 203, 110, 0.05);
        }

        .roadmap-item .tags .tag-plan {
            color: #74b9ff;
            border-color: rgba(116, 185, 255, 0.2);
            background: rgba(116, 185, 255, 0.05);
        }

        .roadmap-item .tags .tag-future {
            color: #a29bfe;
            border-color: rgba(162, 155, 254, 0.2);
            background: rgba(162, 155, 254, 0.05);
        }

        /* ===== FEATURES GRID ===== */
        .features-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 16px;
        }

        .feature-card {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.04);
            border-radius: 12px;
            padding: 18px 20px;
            transition: all 0.3s ease;
        }

        .feature-card:hover {
            background: rgba(255, 255, 255, 0.04);
            border-color: rgba(253, 203, 110, 0.1);
            transform: translateY(-2px);
        }

        .feature-card .icon {
            font-size: 24px;
            color: #fdcb6e;
            margin-bottom: 8px;
            display: block;
        }

        .feature-card h4 {
            font-size: 15px;
            font-weight: 600;
            color: #e0e0e0;
            margin-bottom: 4px;
        }

        .feature-card p {
            font-size: 13px;
            color: #8892a0;
            line-height: 1.6;
        }

        .feature-card .status {
            display: inline-block;
            font-size: 10px;
            font-weight: 600;
            padding: 2px 10px;
            border-radius: 12px;
            margin-top: 8px;
        }

        .status-done {
            color: #81c784;
            background: rgba(129, 199, 132, 0.1);
        }
        .status-progress {
            color: #fdcb6e;
            background: rgba(253, 203, 110, 0.1);
        }
        .status-plan {
            color: #74b9ff;
            background: rgba(116, 185, 255, 0.1);
        }
        .status-future {
            color: #a29bfe;
            background: rgba(162, 155, 254, 0.1);
        }

        /* ===== FOOTER ===== */
        .footer {
            text-align: center;
            padding: 30px 0 20px;
            border-top: 1px solid rgba(255, 255, 255, 0.04);
            margin-top: 20px;
        }

        .footer p {
            color: #5a6a6a;
            font-size: 13px;
        }

        .footer .links {
            margin-top: 8px;
            display: flex;
            gap: 16px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .footer .links a {
            color: #5a6a6a;
            text-decoration: none;
            font-size: 13px;
            transition: color 0.3s ease;
        }

        .footer .links a:hover {
            color: #fdcb6e;
        }

        .footer .links .sep {
            color: #3a4a4a;
        }

        /* ===== RESPONSIVE ===== */
        @media (max-width: 768px) {
            .header h1 {
                font-size: 26px;
            }
            .header .subtitle {
                font-size: 15px;
            }
            .section-title {
                font-size: 22px;
            }
            .roadmap {
                padding-left: 30px;
            }
            .roadmap-item {
                padding: 16px 18px;
            }
            .roadmap-item::before {
                left: -24px;
                width: 12px;
                height: 12px;
                top: 24px;
            }
            .features-grid {
                grid-template-columns: 1fr;
            }
            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }
            .roadmap-item .title {
                font-size: 17px;
            }
        }

        @media (max-width: 480px) {
            body {
                padding: 12px;
            }
            .header h1 {
                font-size: 20px;
            }
            .header .logo .coatsmall {
                width: 32px;
                height: 38px;
            }
            .roadmap {
                padding-left: 22px;
            }
            .roadmap-item::before {
                left: -16px;
                width: 10px;
                height: 10px;
                top: 22px;
            }
            .stats-grid {
                grid-template-columns: 1fr 1fr;
                gap: 10px;
            }
            .stat-card .number {
                font-size: 24px;
            }
            .stat-card {
                padding: 12px 14px;
            }
        }
    </style>
</head>
<body>

