    <script>
        // ===== ОНОВЛЕННЯ ЧАСУ =====
        function updateTime() {
            const el = document.getElementById('last-update');
            const now = new Date();
            el.textContent = now.toLocaleDateString('uk-UA') + ' ' + 
                now.toLocaleTimeString('uk-UA', {hour:'2-digit', minute:'2-digit'});
        }
        setInterval(updateTime, 60000);
        updateTime();

        // ===== ОНОВЛЕННЯ KPI =====
        function refreshKPI() {
            document.getElementById('kpi-temp').textContent = (18 + Math.random() * 6).toFixed(1);
            document.getElementById('kpi-aqi').textContent = Math.floor(20 + Math.random() * 40);
            document.getElementById('kpi-water').textContent = (2.5 + Math.random() * 0.8).toFixed(2);
            document.getElementById('kpi-oil').textContent = Math.floor(2100 + Math.random() * 400).toLocaleString();
            document.getElementById('kpi-ozokerite').textContent = Math.floor(160 + Math.random() * 50);
            document.getElementById('kpi-incidents').textContent = Math.floor(Math.random() * 3);
            document.getElementById('kpi-tourists').textContent = Math.floor(1000 + Math.random() * 600).toLocaleString();
            showNotification('KPI оновлено', 'success');
        }

        // ===== КЕРУВАННЯ ПАРСЕРАМИ =====
        const parserStatus = { weather: true, aqi: true, oil: false, incident: false, water: true, cavibara: true };

        function toggleParser(name) {
            parserStatus[name] = !parserStatus[name];
            const statusEl = document.getElementById('status-' + name);
            const btn = statusEl.closest('tr').querySelector('button');
            if (parserStatus[name]) {
                statusEl.className = 'badge success';
                statusEl.innerHTML = '<i class="fas fa-play"></i> Активний';
                btn.innerHTML = '<i class="fas fa-pause"></i>';
                showNotification('Парсер ' + name + ' запущено', 'success');
            } else {
                statusEl.className = 'badge warning';
                statusEl.innerHTML = '<i class="fas fa-pause"></i> Призупинено';
                btn.innerHTML = '<i class="fas fa-play"></i>';
                showNotification('Парсер ' + name + ' призупинено', 'warning');
            }
        }

        function toggleAllParsers() {
            const names = ['weather', 'aqi', 'oil', 'incident', 'water', 'cavibara'];
            let allActive = names.every(n => parserStatus[n]);
            const newStatus = !allActive;
            names.forEach(n => {
                parserStatus[n] = newStatus;
                const statusEl = document.getElementById('status-' + n);
                const btn = statusEl.closest('tr').querySelector('button');
                if (newStatus) {
                    statusEl.className = 'badge success';
                    statusEl.innerHTML = '<i class="fas fa-play"></i> Активний';
                    btn.innerHTML = '<i class="fas fa-pause"></i>';
                } else {
                    statusEl.className = 'badge warning';
                    statusEl.innerHTML = '<i class="fas fa-pause"></i> Призупинено';
                    btn.innerHTML = '<i class="fas fa-play"></i>';
                }
            });
            showNotification(newStatus ? 'Всі парсери запущено' : 'Всі парсери призупинено', 'info');
        }

        // ===== СПОВІЩЕННЯ =====
        function showNotification(message, type = 'info') {
            const colors = { success: '#22c55e', warning: '#eab308', error: '#ef4444', info: '#60a5fa' };
            const el = document.createElement('div');
            el.style.cssText = `
                position: fixed; top: 20px; right: 20px;
                background: rgba(10, 14, 23, 0.95);
                border-left: 4px solid ${colors[type] || colors.info};
                padding: 14px 20px; border-radius: 10px; z-index: 9999;
                font-size: 14px; color: #e2e8f0; max-width: 360px;
                box-shadow: 0 8px 32px rgba(0,0,0,0.6);
                backdrop-filter: blur(12px);
                border: 1px solid rgba(51,65,85,0.4);
                animation: slideIn 0.3s ease-out;
                font-family: 'Inter', sans-serif;
            `;
            el.innerHTML = `<div style="display:flex;align-items:center;gap:10px;">
                <span style="color:${colors[type]};font-weight:600;">${type.toUpperCase()}</span>
                <span>${message}</span>
            </div>`;
            document.body.appendChild(el);
            setTimeout(() => { el.style.opacity = '0'; el.style.transition = 'opacity 0.4s'; setTimeout(() => el.remove(), 400); }, 3000);
        }

        // ===== МОДУЛЬ API =====
        function sendTestNotification(channel) {
            const msgs = {
                telegram: "🚨 Тестове сповіщення з Цифрового Двійника Борислава",
                whatsapp: "✅ WhatsApp інтеграція працює. Температура: 21.4°C",
                signal: "Signal: Рівень води в Тисмениці — 2.85 м (норма)"
            };
            showNotification(`Тестове повідомлення надіслано в ${channel.toUpperCase()}`, 'success');
            console.log(`%c[INTEGRATION] ${channel.toUpperCase()} → ${msgs[channel]}`, 'color:#fdcb6e');
        }

        function testAllNotifications() {
            showNotification('Тестові сповіщення надіслано у всі канали', 'success');
            console.log('%c[ALL CHANNELS] Тестові повідомлення відправлено', 'color:#22c55e;font-weight:bold');
        }

        setInterval(refreshKPI, 10000);

        console.log('🚀 Модуль парсингу Борислава завантажено!');
