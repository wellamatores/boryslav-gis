<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Цифровий Двійник Борислава — Модуль Парсингу + API</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', system-ui, sans-serif;
            background: #0a0e17;
            color: #e2e8f0;
            line-height: 1.6;
            min-height: 100vh;
        }

        header {
            background: rgba(10, 14, 23, 0.95);
            backdrop-filter: blur(12px);
            position: sticky;
            top: 0;
            z-index: 100;
            border-bottom: 1px solid rgba(51, 65, 85, 0.4);
            padding: 16px 0;
        }

        .container {
            max-width: 1300px;
            margin: 0 auto;
            padding: 0 24px;
        }

        .header-content {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 16px;
        }

        .header-left {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        /* ===== НОВИЙ ЧІП ІЗ ПТЕРОДАКТЕЛЕМ ===== */
        .chip-logo {
            width: 54px;
            height: 64px;
            background: #0f1f0f;
            border-radius: 14px;
            padding: 5px;
            box-shadow: 0 0 0 1.5px #1a3a1a, 0 0 0 3px #2a5a2a, 0 4px 20px rgba(0,0,0,0.6);
            flex-shrink: 0;
            position: relative;
            transition: transform 0.3s ease;
            border: 1px solid #3a7a3a;
        }

        .chip-logo:hover {
            transform: scale(1.08);
            box-shadow: 0 0 0 1.5px #1a3a1a, 0 0 0 3px #2a5a2a, 0 0 30px rgba(0, 200, 0, 0.15);
        }

        .chip-logo .chip-bg {
            width: 100%;
            height: 100%;
            background: radial-gradient(ellipse at center, #1a5a1a 0%, #0d3a0d 100%);
            border-radius: 10px;
            display: flex;
            justify-content: center;
            align-items: center;
            position: relative;
            overflow: hidden;
            border: 1px solid #2a6a2a;
        }

        /* Дорожки */
        .chip-logo .traces {
            position: absolute;
            width: 100%;
            height: 100%;
            top: 0;
            left: 0;
            pointer-events: none;
            opacity: 0.2;
        }
        .chip-logo .trace {
            position: absolute;
            background: #3a8a3a;
            border-radius: 2px;
        }
        .chip-logo .trace-h { height: 1.5px; width: 18px; }
        .chip-logo .trace-v { width: 1.5px; height: 18px; }
        .chip-logo .t1 { top: 6px; left: 4px; width: 22px; }
        .chip-logo .t2 { top: 6px; right: 4px; width: 22px; }
        .chip-logo .t3 { bottom: 6px; left: 4px; width: 22px; }
        .chip-logo .t4 { bottom: 6px; right: 4px; width: 22px; }
        .chip-logo .t5 { top: 4px; left: 6px; height: 22px; }
        .chip-logo .t6 { top: 4px; right: 6px; height: 22px; }
        .chip-logo .t7 { bottom: 4px; left: 6px; height: 22px; }
        .chip-logo .t8 { bottom: 4px; right: 6px; height: 22px; }

        /* Пади */
        .chip-logo .pads {
            position: absolute;
            width: 100%;
            height: 100%;
            top: 0;
            left: 0;
            pointer-events: none;
        }
        .chip-logo .pad {
            position: absolute;
            width: 5px;
            height: 5px;
            background: #4a8a4a;
            border-radius: 50%;
            box-shadow: 0 0 4px rgba(74, 138, 74, 0.4);
        }
        .chip-logo .p1 { top: 7px; left: 7px; }
        .chip-logo .p2 { top: 7px; right: 7px; }
        .chip-logo .p3 { bottom: 7px; left: 7px; }
        .chip-logo .p4 { bottom: 7px; right: 7px; }
        .chip-logo .p5 { top: 50%; left: 4px; transform: translateY(-50%); }
        .chip-logo .p6 { top: 50%; right: 4px; transform: translateY(-50%); }
        .chip-logo .p7 { top: 4px; left: 50%; transform: translateX(-50%); }
        .chip-logo .p8 { bottom: 4px; left: 50%; transform: translateX(-50%); }

        /* ===== ТРИЗУБ-ПТЕРОДАКТЕЛЬ ===== */
        .tryzub-icon {
            position: relative;
            z-index: 5;
            width: 28px;
            height: 32px;
            filter: drop-shadow(0 0 12px rgba(255, 215, 0, 0.2));
            animation: breathe-glow 3s ease-in-out infinite;
        }

        .tryzub-icon svg {
            width: 100%;
            height: 100%;
            display: block;
        }

        @keyframes breathe-glow {
            0%, 100% {
                filter: drop-shadow(0 0 8px rgba(255, 215, 0, 0.15));
                transform: scale(1);
            }
            50% {
                filter: drop-shadow(0 0 20px rgba(255, 215, 0, 0.35));
                transform: scale(1.04);
            }
        }

        /* Світловий ореол навколо чіпа */
        .chip-logo .glow-ring {
            position: absolute;
            width: 60px;
            height: 60px;
            border-radius: 50%;
            border: 1.5px solid rgba(255, 215, 0, 0.06);
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            pointer-events: none;
            animation: pulse-ring 4s ease-in-out infinite;
        }
        @keyframes pulse-ring {
            0%, 100% { transform: translate(-50%, -50%) scale(0.9); opacity: 0.2; }
            50% { transform: translate(-50%, -50%) scale(1.3); opacity: 0.6; }
        }

        /* ===== ХЕДЕР ===== */
        .header-title h1 {
            font-size: 22px;
            font-weight: 800;
            background: linear-gradient(135deg, #fdcb6e, #f39c12);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            letter-spacing: -0.5px;
        }

        .header-title .sub {
            font-size: 13px;
            color: #8892a0;
            -webkit-text-fill-color: #8892a0;
        }

        .header-title .sub strong {
            color: #fdcb6e;
            -webkit-text-fill-color: #fdcb6e;
        }

        .header-version {
            background: rgba(253, 203, 110, 0.12);
            border: 1px solid rgba(253, 203, 110, 0.2);
            border-radius: 20px;
            padding: 4px 16px;
            font-size: 12px;
            font-weight: 600;
            color: #fdcb6e;
            white-space: nowrap;
        }

        /* ===== ГЕРБ У ХЕДЕРІ ===== */
        .header-coat-of-arms {
            display: flex;
            align-items: center;
            gap: 8px;
            background: rgba(30, 41, 55, 0.6);
            padding: 4px 14px 4px 8px;
            border-radius: 40px;
            border: 1px solid rgba(253, 203, 110, 0.2);
            backdrop-filter: blur(4px);
        }

        .header-coat-of-arms .shield-mini {
            width: 38px;
            height: 44px;
            background: linear-gradient(135deg, #1a3d7a 0%, #1a3d7a 50%, #b31b1b 50%, #b31b1b 100%);
            border-radius: 20% 20% 10% 10% / 30% 30% 12% 12%;
            position: relative;
            flex-shrink: 0;
            box-shadow: 0 0 0 2px #c9b393;
            overflow: hidden;
        }

        .header-coat-of-arms .shield-mini .mini-megalith {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 12px;
            height: 34px;
            background: linear-gradient(135deg, #e8e0d0, #b8b0a0);
            border-radius: 4px 4px 2px 2px;
            box-shadow: 0 0 0 1px #a09888;
            border-top: 2px solid #d8d0c0;
        }
        .header-coat-of-arms .shield-mini .mini-megalith::before {
            content: '';
            position: absolute;
            top: -6px;
            left: -4px;
            width: 20px;
            height: 6px;
            background: #d8d0c0;
            border-radius: 10px 10px 2px 2px;
        }
        .header-coat-of-arms .shield-mini .mini-drop {
            position: absolute;
            width: 6px; height: 8px;
            background: #1f1f1f;
            border-radius: 50% 50% 50% 50% / 40% 40% 60% 60%;
            transform: rotate(20deg);
            opacity: 0.7;
        }
        .header-coat-of-arms .shield-mini .mini-drop.d1 { top: 10%; left: 12%; }
        .header-coat-of-arms .shield-mini .mini-drop.d2 { bottom: 14%; right: 10%; }
        .header-coat-of-arms .shield-mini .mini-oz {
            position: absolute;
            width: 8px; height: 8px;
            background: #f7d44a;
            clip-path: polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%);
            opacity: 0.6;
        }
        .header-coat-of-arms .shield-mini .mini-oz.o1 { top: 20%; right: 6%; }
        .header-coat-of-arms .shield-mini .mini-oz.o2 { bottom: 24%; left: 6%; }

        .header-coat-of-arms .coat-label {
            font-size: 11px;
            font-weight: 600;
            color: #fdcb6e;
            letter-spacing: 0.3px;
            white-space: nowrap;
        }
        .header-coat-of-arms .coat-label small {
            display: block;
            font-size: 8px;
            color: #8892a0;
            font-weight: 400;
            letter-spacing: 0.2px;
        }

        /* ===== ЛЕГЕНДА ПІД ЧІПОМ ===== */
        .chip-legend {
            font-size: 10px;
            color: #5a7a5a;
            text-align: center;
            letter-spacing: 0.3px;
            margin-top: 2px;
            font-style: italic;
            max-width: 120px;
            line-height: 1.2;
        }
        .chip-legend strong {
            color: #f7d44a;
            font-style: normal;
        }

        /* ===== СТАТУС-БАР, КАРТКИ ТОЩО (без змін) ===== */
        .status-bar {
            background: rgba(30, 41, 55, 0.8);
            backdrop-filter: blur(8px);
            padding: 16px 24px;
            border-radius: 14px;
            margin: 20px 0 28px;
            border: 1px solid rgba(51, 65, 85, 0.4);
            display: flex;
            gap: 32px;
            flex-wrap: wrap;
            align-items: center;
        }
        .status-item {
            display: flex;
            flex-direction: column;
            gap: 2px;
        }
        .status-item .label {
            font-size: 11px;
            color: #8892a0;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .status-item .value {
            font-size: 15px;
            font-weight: 600;
            color: #e2e8f0;
        }
        .badge {
            display: inline-block;
            padding: 2px 14px;
            border-radius: 9999px;
            font-size: 12px;
            font-weight: 600;
        }
        .badge.success { background: rgba(34, 197, 94, 0.2); color: #22c55e; border: 1px solid rgba(34, 197, 94, 0.3); }
        .badge.warning { background: rgba(234, 179, 8, 0.2); color: #eab308; border: 1px solid rgba(234, 179, 8, 0.3); }
        .badge.danger { background: rgba(239, 68, 68, 0.2); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.3); }
        .badge.info { background: rgba(96, 165, 250, 0.2); color: #60a5fa; border: 1px solid rgba(96, 165, 250, 0.3); }

        .card {
            background: rgba(30, 41, 55, 0.8);
            backdrop-filter: blur(8px);
            border-radius: 14px;
            padding: 20px 24px;
            margin-bottom: 20px;
            border: 1px solid rgba(51, 65, 85, 0.4);
            transition: all 0.3s ease;
        }
        .card:hover { border-color: rgba(253, 203, 110, 0.2); box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3); }
        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 16px;
            flex-wrap: wrap;
            gap: 8px;
        }
        .card-header h2 {
            font-size: 18px;
            font-weight: 700;
            color: #e2e8f0;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .card-header h2 i { color: #fdcb6e; }
        .card-header .card-actions { display: flex; gap: 8px; }
        .btn {
            padding: 6px 16px;
            border-radius: 8px;
            border: 1px solid rgba(51, 65, 85, 0.4);
            background: transparent;
            color: #e2e8f0;
            font-size: 13px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s ease;
            font-family: 'Inter', sans-serif;
        }
        .btn:hover { background: rgba(253, 203, 110, 0.1); border-color: rgba(253, 203, 110, 0.3); color: #fdcb6e; }
        .btn-primary { background: rgba(253, 203, 110, 0.15); border-color: rgba(253, 203, 110, 0.3); color: #fdcb6e; }
        .btn-primary:hover { background: rgba(253, 203, 110, 0.25); }

        .table-wrap { overflow-x: auto; }
        table { width: 100%; border-collapse: collapse; font-size: 14px; }
        th { text-align: left; padding: 12px 16px; color: #8892a0; font-weight: 600; font-size: 12px; text-transform: uppercase; letter-spacing: 0.5px; border-bottom: 1px solid rgba(51, 65, 85, 0.4); }
        td { padding: 12px 16px; border-bottom: 1px solid rgba(51, 65, 85, 0.2); color: #e2e8f0; }
        tr:hover td { background: rgba(255, 255, 255, 0.02); }
        .priority-high { color: #ef4444; font-weight: 600; }
        .priority-med { color: #eab308; font-weight: 600; }

        .arch-flow {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            justify-content: center;
            gap: 8px 4px;
            padding: 20px;
            background: rgba(10, 14, 23, 0.6);
            border-radius: 12px;
            font-size: 13px;
            font-weight: 500;
        }
        .arch-flow .block {
            padding: 8px 20px;
            border-radius: 8px;
            background: rgba(253, 203, 110, 0.08);
            border: 1px solid rgba(253, 203, 110, 0.15);
            white-space: nowrap;
            color: #e2e8f0;
        }
        .arch-flow .block i { color: #fdcb6e; margin-right: 6px; }
        .arch-flow .arrow { color: #64748b; font-size: 18px; }

        .integration-card {
            background: rgba(30, 41, 55, 0.8);
            border-radius: 14px;
            padding: 18px;
            border: 1px solid rgba(51, 65, 85, 0.4);
        }
        .channel {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 12px 16px;
            background: rgba(15, 23, 42, 0.6);
            border-radius: 10px;
            margin-bottom: 10px;
        }
        .api-endpoint {
            font-family: monospace;
            background: #1e2937;
            padding: 8px 12px;
            border-radius: 6px;
            font-size: 13px;
            color: #94a3b8;
        }

        footer {
            text-align: center;
            padding: 32px 0 24px;
            color: #64748b;
            font-size: 14px;
            border-top: 1px solid rgba(51, 65, 85, 0.2);
            margin-top: 20px;
        }
        footer strong { color: #fdcb6e; }

        /* ===== АДАПТИВ ===== */
        @media (max-width: 768px) {
            .header-content { flex-direction: column; align-items: flex-start; }
            .header-title h1 { font-size: 18px; }
            .header-title .sub { font-size: 12px; }
            .status-bar { padding: 14px 18px; gap: 16px; }
            .status-item .value { font-size: 13px; }
            .card { padding: 16px 18px; }
            .arch-flow { flex-direction: column; gap: 6px; padding: 16px; }
            .arch-flow .arrow { transform: rotate(90deg); }
            th, td { padding: 8px 12px; font-size: 13px; }
            .header-version { font-size: 10px; padding: 2px 12px; }
            .header-coat-of-arms .coat-label { font-size: 9px; }
            .header-coat-of-arms .coat-label small { font-size: 7px; }
            .header-coat-of-arms .shield-mini { width: 30px; height: 36px; }
            .header-coat-of-arms .shield-mini .mini-megalith { width: 10px; height: 26px; }
            .header-coat-of-arms .shield-mini .mini-megalith::before { width: 16px; height: 5px; top: -5px; left: -3px; }
            .chip-logo { width: 44px; height: 52px; padding: 4px; }
            .tryzub-icon { width: 22px; height: 26px; }
            .chip-logo .glow-ring { width: 48px; height: 48px; }
            .chip-legend { font-size: 8px; max-width: 90px; }
            .channel { flex-wrap: wrap; gap: 8px; }
        }

        @media (max-width: 480px) {
            .header-title h1 { font-size: 15px; }
            .header-title .sub { font-size: 10px; }
            .status-item .label { font-size: 9px; }
            .status-item .value { font-size: 12px; }
            .card-header h2 { font-size: 15px; }
            .btn { font-size: 11px; padding: 4px 12px; }
            table { font-size: 12px; }
            th, td { padding: 6px 10px; }
            .badge { font-size: 10px; padding: 1px 10px; }
            .header-coat-of-arms { padding: 2px 10px 2px 6px; }
            .header-coat-of-arms .coat-label { font-size: 8px; }
            .header-coat-of-arms .coat-label small { font-size: 6px; }
            .header-coat-of-arms .shield-mini { width: 26px; height: 30px; }
            .header-coat-of-arms .shield-mini .mini-megalith { width: 8px; height: 20px; }
            .header-coat-of-arms .shield-mini .mini-megalith::before { width: 14px; height: 4px; top: -4px; left: -3px; }
            .chip-logo { width: 36px; height: 44px; padding: 3px; }
            .tryzub-icon { width: 18px; height: 22px; }
            .chip-logo .glow-ring { width: 40px; height: 40px; }
            .chip-legend { font-size: 7px; max-width: 70px; }
        }
    </style>
</head>
<body>

    <header>
        <div class="container">
            <div class="header-content">
                <div class="header-left">
                    <!-- ===== НОВИЙ ЧІП ІЗ ПТЕРОДАКТЕЛЕМ ===== -->
                    <div style="display:flex;flex-direction:column;align-items:center;">
                        <div class="chip-logo">
                            <div class="chip-bg">
                                <div class="traces">
                                    <div class="trace trace-h t1"></div>
                                    <div class="trace trace-h t2"></div>
                                    <div class="trace trace-h t3"></div>
                                    <div class="trace trace-h t4"></div>
                                    <div class="trace trace-v t5"></div>
                                    <div class="trace trace-v t6"></div>
                                    <div class="trace trace-v t7"></div>
                                    <div class="trace trace-v t8"></div>
                                </div>
                                <div class="pads">
                                    <div class="pad p1"></div>
                                    <div class="pad p2"></div>
                                    <div class="pad p3"></div>
                                    <div class="pad p4"></div>
                                    <div class="pad p5"></div>
                                    <div class="pad p6"></div>
                                    <div class="pad p7"></div>
                                    <div class="pad p8"></div>
                                </div>
                                <div class="glow-ring"></div>
                                <div class="tryzub-icon">
                                    <svg viewBox="0 0 100 120" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M50 15 L35 50 L35 55 L50 40 L65 55 L65 50 L50 15Z" fill="#f7d44a" stroke="#d4a017" stroke-width="1.5"/>
                                        <path d="M18 45 L35 50 L35 40 L18 35Z" fill="#f7d44a" stroke="#d4a017" stroke-width="1.5"/>
                                        <path d="M82 45 L65 50 L65 40 L82 35Z" fill="#f7d44a" stroke="#d4a017" stroke-width="1.5"/>
                                        <path d="M50 10 L50 35 L40 40 L50 28 L60 40 L50 35Z" fill="#f7d44a" stroke="#d4a017" stroke-width="1.5"/>
                                        <ellipse cx="45" cy="30" rx="8" ry="4" fill="rgba(255,255,240,0.12)" transform="rotate(-20, 45, 30)"/>
                                    </svg>
                                </div>
                            </div>
                        </div>
                        <!-- Легенда під чіпом -->
                        <div class="chip-legend">
                            <strong>Птеродактель</strong> — символ цифрової трансформації Борислава 🦅
                        </div>
                    </div>

                    <div class="header-title">
                        <h1>Цифровий Двійник Борислава</h1>
                        <div class="sub">
                            <strong>Модуль постійного парсингу</strong> та оновлення даних
                        </div>
                    </div>
                </div>

                <!-- Герб у хедері -->
                <div class="header-coat-of-arms">
                    <div class="shield-mini">
                        <div class="mini-megalith"></div>
                        <div class="mini-drop d1"></div>
                        <div class="mini-drop d2"></div>
                        <div class="mini-oz o1"></div>
                        <div class="mini-oz o2"></div>
                    </div>
                    <span class="coat-label">
                        BORYSLАV
                        <small>Sal · Commercium · Vita</small>
                    </span>
                </div>

                <div class="header-version">
                    <i class="fas fa-code-branch"></i> v2.0 &bull; 2026-07-03
                </div>
            </div>
        </div>
    </header>

    <div class="container">

        <!-- ===== СТАТУС-БАР ===== -->
        <div class="status-bar">
            <div class="status-item">
                <span class="label"><i class="fas fa-circle" style="color:#22c55e;font-size:8px;"></i> Статус системи</span>
                <span class="value"><span class="badge success"><i class="fas fa-check"></i> Працює</span></span>
            </div>
            <div class="status-item">
                <span class="label"><i class="far fa-clock"></i> Останнє оновлення</span>
                <span class="value" id="last-update">03.07.2026 08:34</span>
            </div>
            <div class="status-item">
                <span class="label"><i class="fas fa-microchip"></i> Активних парсерів</span>
                <span class="value"><strong style="color:#fdcb6e;">4</strong> / 9</span>
            </div>
            <div class="status-item">
                <span class="label"><i class="fas fa-sync-alt"></i> Синхронізація Cavibara</span>
                <span class="value"><span class="badge success"><i class="fas fa-check"></i> Активна</span></span>
            </div>
            <div class="status-item">
                <span class="label"><i class="fas fa-database"></i> Свіжість даних</span>
                <span class="value"><span class="badge success"><i class="fas fa-check-circle"></i> Відмінна</span></span>
            </div>
        </div>

        <!-- ===== KPI ===== -->
        <div class="card">
            <div class="card-header">
